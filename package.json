{
  "name": "whatsapp-opencode",
  "version": "2.2.0",
  "bin": {
    "wao": "./bin/wao.js"
  },
  "description": "通过 WhatsApp 控制 OpenCode AI 助手",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js",
    "test": "jest",
    "lint": "eslint .",
    "test:coverage": "jest --coverage",
    "test:integration": "npm test",
    "version:patch": "npm version patch --no-git-tag-version && git add package.json",
    "version:minor": "npm version minor --no-git-tag-version && git add package.json",
    "version:major": "npm version major --no-git-tag-version && git add package.json",
    "release": "git push --tags && gh release create v$(node -p \"require('./package.json').version\") --generate-notes",
    "prepublishOnly": "npm run lint && npm run test:coverage"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "README.md",
    "LICENSE",
    "RELEASE_NOTES.md",
    ".env.example"
  ],
  "keywords": [
    "opencode",
    "whatsapp",
    "ai",
    "assistant",
    "bridge",
    "chatbot"
  ],
  "author": "Jinghai <jinghai@email.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jinghai/whatsapp-opencode.git"
  },
  "bugs": {
    "url": "https://github.com/jinghai/whatsapp-opencode/issues"
  },
  "homepage": "https://github.com/jinghai/whatsapp-opencode#readme",
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "axios": "^1.13.5",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "dotenv": "^16.4.5",
    "form-data": "^4.0.5",
    "inquirer": "^8.2.7",
    "open": "^11.0.0",
    "ora": "^5.4.1",
    "pino": "^10.3.1",
    "pm2": "^6.0.14",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
