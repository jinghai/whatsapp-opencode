  "description": "Bridge WhatsApp messages to OpenCode AI assistant - control your OpenCode via WhatsApp",
  "main": "src/bridge.js",
  "scripts": {
    "start": "node src/bridge.js",
    "dev": "nodemon src/bridge.js",
