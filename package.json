    "assistant",
    "baileys"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinghai/opencode-whatsapp-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/jinghai/opencode-whatsapp-bridge/issues"
  },
  "homepage": "https://github.com/jinghai/opencode-whatsapp-bridge#readme",
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "axios": "^1.13.5",
    "dotenv": "^16.3.1",
    "form-data": "^4.0.0",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.0",
    "@commitlint/config-conventional": "^18.4.0",
    "eslint": "^8.55.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
