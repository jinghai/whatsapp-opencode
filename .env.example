# OpenCode API URL
OPENCODE_URL=http://127.0.0.1:4096

# SiliconFlow API Key（用于语音转文字与图片 OCR，选填）
SILICONFLOW_KEY=your_siliconflow_api_key_here

# 白名单（可选）：只允许特定手机号访问，用逗号分隔
# 例如：ALLOWLIST=8613800138000,8613900139000
ALLOWLIST=

# OpenCode 图片能力策略：
# auto   -> 先直传图片给 OpenCode，不支持时自动 OCR 回退（默认）
# direct -> 强制直传图片给 OpenCode
# ocr    -> 强制先 OCR 再把文字发给 OpenCode
OPENCODE_IMAGE_CAPABILITY=auto

# 工作目录
WORKING_DIR=./

# 调试模式
DEBUG=false

# 测试消息发送目标（可选）
TEST_JID=
